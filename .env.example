# ------------------------------------------------------------------
# PULSE environment. Everything is OPTIONAL — the app runs fully in
# local Demo Mode with no keys. Add keys to enable real Gemini + Firebase.
# Copy to `.env.local` and fill in.
# ------------------------------------------------------------------

# --- Gemini (server-side only; never exposed to the browser) ---
# Enables real AI reasoning. Without it, PULSE uses its heuristic engine.
GEMINI_API_KEY=
# Optional model override (defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash
# Display-only label for the model shown in the decision ledger / engine badge.
# Not a secret; keep it in sync with GEMINI_MODEL if you override the model above.
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.0-flash

# --- Firebase (optional; enables auth + multi-console Firestore sync) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
